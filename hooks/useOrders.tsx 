// src/hooks/useOrders.ts
import useSWR from "swr";

const fetcher = (url: string) => fetch(url).then((r) => r.json());

export function useOrders(date: string) {
  const { data, error, isLoading } = useSWR(
    `/api/orders?date=${date}`,
    fetcher
  );

  return {
    orders: data?.data ?? [],
    isLoading,
    isError: error,
  };
}
